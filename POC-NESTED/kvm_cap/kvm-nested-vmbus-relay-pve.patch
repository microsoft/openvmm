+				vcpu, hc.ingpa, PFERR_GUEST_FINAL_MASK, NULL, 0);
+		if (unlikely(hc.ingpa == INVALID_GPA)) {
+			ret = HV_STATUS_INVALID_HYPERCALL_INPUT;
+			goto hypercall_complete;
+		}
+	}
+
 	switch (hc.code) {
 	case HVCALL_NOTIFY_LONG_SPIN_WAIT:
 		if (unlikely(hc.rep || hc.var_cnt)) {
